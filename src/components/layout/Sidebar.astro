---
import { Icon } from 'astro-icon/components';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/', icon: 'home' },
  {
    label: 'Work',
    href: '/work',
    icon: 'briefcase',
    children: [
      { label: 'Orbital Concierge', href: '/work/orbital-concierge' },
    ],
  },
  { label: 'About', href: '/about', icon: 'user' },
  { label: 'Contact', href: '/#contact', icon: 'mail' },
];

function isActive(href: string, current: string): boolean {
  const normalizedCurrent = current.replace(/\/$/, '') || '/';
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedCurrent === normalizedHref;
}

const isWorkSubpage = currentPath.startsWith('/work/');
const isWorkSection = currentPath.startsWith('/work');
---
<aside class="sidebar">
  <nav aria-label="Site navigation">
    <ul class="sidebar__nav">
      {navItems.map((item) => (
        <li class={item.children ? 'nav-folder' : ''}>
          {item.children ? (
            <>
              <div class="nav-folder__header">
                <a
                  href={item.href}
                  class="sidebar__link"
                  data-nav-link
                  aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
                >
                  <Icon name={item.icon} size={24} />
                  <span class="sidebar__label mono-label">{item.label}</span>
                </a>
                <button
                  class="nav-folder__trigger"
                  type="button"
                  aria-expanded={isWorkSubpage ? 'true' : 'false'}
                  aria-controls="work-children"
                  aria-label={`Toggle ${item.label} submenu`}
                >
                  <Icon name="chevron-down" size={16} class="nav-folder__chevron" />
                </button>
              </div>
              <div
                id="work-children"
                class="nav-folder__children"
                aria-hidden={isWorkSubpage ? 'false' : 'true'}
              >
                <ul class="nav-folder__children-inner">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="nav-folder__child"
                        data-nav-link
                        aria-current={isActive(child.href, currentPath) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class="sidebar__link"
              data-nav-link
              aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
            >
              <Icon name={item.icon} size={24} />
              <span class="sidebar__label mono-label">{item.label}</span>
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar__bottom">
    <ThemeToggle />
  </div>
</aside>


<script>
  // Bind click handlers once, not on every page-load (prevents duplicate listeners)
  document.addEventListener('click', (e) => {
    const trigger = (e.target as Element).closest('.nav-folder__trigger');
    if (!trigger) return;
    const targetId = trigger.getAttribute('aria-controls');
    if (!targetId) return;
    const target = document.getElementById(targetId);
    if (!target) return;
    const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
    trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
    target.setAttribute('aria-hidden', isExpanded ? 'true' : 'false');
  });

  // Update nav state on each navigation
  document.addEventListener('astro:page-load', () => {
    const currentPath = window.location.pathname;

    // Update aria-current on all nav links
    document.querySelectorAll('[data-nav-link]').forEach(link => {
      const href = link.getAttribute('href');
      if (!href) return;
      // Skip hash-only links (Contact is an anchor, not a page)
      if (href.includes('#')) {
        link.removeAttribute('aria-current');
        return;
      }
      const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
      const normalizedHref = href.replace(/\/$/, '') || '/';
      const isActive = normalizedCurrent === normalizedHref;
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    // Auto-expand Work folder if on a work subpage
    const workChildren = document.getElementById('work-children');
    const workTrigger = document.querySelector('[aria-controls="work-children"]');
    if (workChildren && workTrigger) {
      const shouldExpand = currentPath.startsWith('/work/');
      workChildren.setAttribute('aria-hidden', shouldExpand ? 'false' : 'true');
      workTrigger.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');
    }

    // Close mobile drawer on navigation (pitfall prevention)
    const drawer = document.querySelector('.mobile-drawer');
    if (drawer && (drawer as HTMLElement).dataset.open === 'true') {
      (drawer as HTMLElement).dataset.open = 'false';
      document.body.style.overflow = '';
    }

    // Contact link: smooth scroll then clear hash so refresh goes to top
    document.querySelectorAll('[href="/#contact"]').forEach(link => {
      link.addEventListener('click', (e) => {
        const onHomepage = (window.location.pathname.replace(/\/$/, '') || '/') === '/';
        if (onHomepage) {
          e.preventDefault();
          const target = document.getElementById('contact');
          if (target) {
            target.scrollIntoView({ behavior: 'smooth' });
            history.replaceState(null, '', '/');
          }
        }
      });
    });

    // On homepage: swap active state to CONTACT when #contact section is in view
    const contactSection = document.getElementById('contact');
    if (contactSection && (currentPath.replace(/\/$/, '') || '/') === '/') {
      const homeLink = document.querySelector('[data-nav-link][href="/"]');
      const contactLink = document.querySelector('[data-nav-link][href="/#contact"]');
      if (homeLink && contactLink) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              homeLink.removeAttribute('aria-current');
              contactLink.setAttribute('aria-current', 'page');
            } else {
              contactLink.removeAttribute('aria-current');
              homeLink.setAttribute('aria-current', 'page');
            }
          });
        }, { threshold: 0.4 });
        observer.observe(contactSection);
      }
    }
  });
</script>
