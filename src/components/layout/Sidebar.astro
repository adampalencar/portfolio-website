---
import { Icon } from 'astro-icon/components';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/', icon: 'home' },
  {
    label: 'Work',
    href: '/work',
    icon: 'briefcase',
    children: [
      { label: 'Orbital Concierge', href: '/work/orbital-concierge' },
    ],
  },
  { label: 'About', href: '/about', icon: 'user' },
  { label: 'Contact', href: '/#contact', icon: 'mail' },
];

function isActive(href: string, current: string): boolean {
  const normalizedCurrent = current.replace(/\/$/, '') || '/';
  const normalizedHref = href.replace(/\/$/, '') || '/';
  return normalizedCurrent === normalizedHref;
}

const isWorkSubpage = currentPath.startsWith('/work/');
const isWorkSection = currentPath.startsWith('/work');
---
<aside class="sidebar">
  <nav aria-label="Main navigation">
    <ul class="sidebar__nav">
      {navItems.map((item) => (
        <li class={item.children ? 'nav-folder' : ''}>
          {item.children ? (
            <>
              <div class="nav-folder__header">
                <a
                  href={item.href}
                  class="sidebar__link"
                  data-nav-link
                  aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
                >
                  <Icon name={item.icon} size={24} />
                  <span class="sidebar__label mono-label">{item.label}</span>
                </a>
                <button
                  class="nav-folder__trigger"
                  type="button"
                  aria-expanded={isWorkSubpage ? 'true' : 'false'}
                  aria-controls="work-children"
                  aria-label={`Toggle ${item.label} submenu`}
                >
                  <Icon name="chevron-down" size={16} class="nav-folder__chevron" />
                </button>
              </div>
              <div
                id="work-children"
                class="nav-folder__children"
                aria-hidden={isWorkSubpage ? 'false' : 'true'}
              >
                <ul class="nav-folder__children-inner">
                  {item.children.map((child) => (
                    <li>
                      <a
                        href={child.href}
                        class="nav-folder__child"
                        data-nav-link
                        aria-current={isActive(child.href, currentPath) ? 'page' : undefined}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </>
          ) : (
            <a
              href={item.href}
              class="sidebar__link"
              data-nav-link
              aria-current={isActive(item.href, currentPath) ? 'page' : undefined}
            >
              <Icon name={item.icon} size={24} />
              <span class="sidebar__label mono-label">{item.label}</span>
            </a>
          )}
        </li>
      ))}
    </ul>
  </nav>

  <div class="sidebar__bottom">
    <ThemeToggle />
  </div>
</aside>

<style>
  @layer components {
    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
      background: var(--bg-secondary);
      border-right: 1px solid var(--border-subtle);
      z-index: var(--z-raised);
      display: flex;
      flex-direction: column;
      padding: var(--space-4) 0;
    }

    .sidebar__nav {
      list-style: none;
      padding: 0;
      margin: 0;
      flex: 1;
    }

    .sidebar__link {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-4);
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 150ms ease, background 150ms ease;
    }

    .sidebar__link:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .sidebar__link[aria-current="page"] {
      color: var(--accent);
      border-left: 3px solid var(--accent);
      padding-left: calc(var(--space-4) - 3px);
    }

    .sidebar__link:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .sidebar__label {
      color: inherit;
    }

    /* --- Nav folder (Work section) --- */

    .nav-folder__header {
      display: flex;
      align-items: center;
    }

    .nav-folder__header .sidebar__link {
      flex: 1;
      min-width: 0;
    }

    .nav-folder__trigger {
      background: none;
      border: none;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-2);
      color: var(--text-secondary);
      transition: color 150ms ease, background 150ms ease;
      border-radius: 4px;
      margin-right: var(--space-2);
    }

    .nav-folder__trigger:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .nav-folder__trigger:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .nav-folder__chevron {
      transition: transform 250ms ease;
    }

    .nav-folder__trigger[aria-expanded="true"] .nav-folder__chevron {
      transform: rotate(180deg);
    }

    /* --- Accordion children --- */

    .nav-folder__children {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 250ms ease;
    }

    .nav-folder__children[aria-hidden="false"] {
      grid-template-rows: 1fr;
    }

    .nav-folder__children-inner {
      overflow: hidden;
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .nav-folder__child {
      display: block;
      padding: var(--space-1) var(--space-4) var(--space-1) calc(var(--space-4) + 32px);
      font-family: var(--font-mono);
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--text-tertiary);
      text-decoration: none;
      transition: color 150ms ease;
    }

    .nav-folder__child:hover {
      color: var(--text-primary);
    }

    .nav-folder__child[aria-current="page"] {
      color: var(--accent);
    }

    .nav-folder__child:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    /* --- Bottom section --- */

    .sidebar__bottom {
      padding: var(--space-3) var(--space-4);
      border-top: 1px solid var(--border-subtle);
    }

    /* --- Responsive: hide below 1200px --- */

    @media (max-width: 1199px) {
      .sidebar {
        display: none;
      }
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const currentPath = window.location.pathname;

    // Update aria-current on all nav links
    document.querySelectorAll('[data-nav-link]').forEach(link => {
      const href = link.getAttribute('href');
      if (!href) return;
      const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
      const normalizedHref = href.replace(/\/$/, '') || '/';
      const isActive = normalizedCurrent === normalizedHref;
      if (isActive) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    // Auto-expand Work folder if on a work subpage
    const workChildren = document.getElementById('work-children');
    const workTrigger = document.querySelector('[aria-controls="work-children"]');
    if (workChildren && workTrigger) {
      const shouldExpand = currentPath.startsWith('/work/');
      workChildren.setAttribute('aria-hidden', shouldExpand ? 'false' : 'true');
      workTrigger.setAttribute('aria-expanded', shouldExpand ? 'true' : 'false');
    }

    // Accordion toggle on click
    const triggers = document.querySelectorAll('.nav-folder__trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetId = trigger.getAttribute('aria-controls');
        if (!targetId) return;
        const target = document.getElementById(targetId);
        if (!target) return;
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
        target.setAttribute('aria-hidden', isExpanded ? 'true' : 'false');
      });
    });

    // Close mobile drawer on navigation (pitfall prevention)
    const drawer = document.querySelector('.mobile-drawer');
    if (drawer && (drawer as HTMLElement).dataset.open === 'true') {
      (drawer as HTMLElement).dataset.open = 'false';
      document.body.style.overflow = '';
    }
  });
</script>
