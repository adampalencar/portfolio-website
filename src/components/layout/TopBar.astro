---
import { Icon } from 'astro-icon/components';
import ThemeToggle from '../ui/ThemeToggle.astro';

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navItems = [
  { label: 'Home', href: '/', icon: 'home' },
  { label: 'Work', href: '/work', icon: 'briefcase' },
  { label: 'About', href: '/about', icon: 'user' },
  { label: 'Contact', href: '/#contact', icon: 'mail' },
];

function getActiveCurrent(href: string, current: string): string | undefined {
  const normalizedCurrent = current.replace(/\/$/, '') || '/';
  const normalizedHref = href.replace(/\/$/, '') || '/';
  if (normalizedCurrent === normalizedHref) return 'page';
  if (normalizedHref !== '/' && normalizedCurrent.startsWith(normalizedHref + '/')) return 'true';
  return undefined;
}
---
<header class="top-bar">
  <span class="top-bar__monogram mono-label">AP</span>

  <nav aria-label="Main navigation">
    <ul class="top-bar__nav">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="top-bar__link"
            data-nav-link
            aria-current={getActiveCurrent(item.href, currentPath)}
          >
            <Icon name={item.icon} size={20} />
            <span class="top-bar__label mono-label">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="top-bar__actions">
    <ThemeToggle />
    <button
      class="top-bar__hamburger"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <Icon name="menu" size={24} />
    </button>
  </div>
</header>

<style>
  @layer components {
    .top-bar {
      display: none;
      align-items: center;
      justify-content: space-between;
      padding: var(--space-2) var(--space-3);
      background: var(--bg-secondary);
      border-bottom: 1px solid var(--border-subtle);
      position: sticky;
      top: 0;
      z-index: var(--z-raised);
    }

    @media (max-width: 1199px) {
      .top-bar {
        display: flex;
      }
    }

    .top-bar__monogram {
      font-size: var(--size-sm);
      font-weight: 600;
      color: var(--text-primary);
    }

    .top-bar__nav {
      display: flex;
      gap: var(--space-3);
      list-style: none;
      padding: 0;
      margin: 0;
    }

    @media (max-width: 767px) {
      .top-bar__nav {
        display: none;
      }
    }

    .top-bar__link {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      color: var(--text-secondary);
      text-decoration: none;
      padding: var(--space-1) var(--space-2);
      border-radius: 4px;
      transition: color 150ms ease, background 150ms ease;
    }

    .top-bar__link:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .top-bar__link[aria-current="page"] {
      color: var(--accent);
    }

    .top-bar__link[aria-current="true"] {
      color: var(--text-primary);
    }

    .top-bar__link:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .top-bar__label {
      color: inherit;
    }

    .top-bar__actions {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .top-bar__hamburger {
      display: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: var(--space-1);
      color: var(--text-secondary);
      border-radius: 4px;
      transition: color 150ms ease, background 150ms ease;
    }

    .top-bar__hamburger:hover {
      color: var(--text-primary);
      background: var(--border-subtle);
    }

    .top-bar__hamburger:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    @media (max-width: 767px) {
      .top-bar__hamburger {
        display: flex;
      }
    }
  }
</style>
