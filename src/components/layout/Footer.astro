---
import { Icon } from 'astro-icon/components';
---
<footer class="site-footer">
  <div class="site-footer__content">
    <a href="mailto:adam@palencar.com" class="site-footer__item">
      <Icon name="mail" size={14} />
      <span>adam@palencar.com</span>
    </a>
    <span class="site-footer__separator" aria-hidden="true">|</span>
    <a href="https://linkedin.com/in/adampalencar" class="site-footer__item" target="_blank" rel="noopener noreferrer">
      <Icon name="link" size={14} />
      <span>LinkedIn</span>
    </a>
    <span class="site-footer__separator" aria-hidden="true">|</span>
    <a href="/resume.pdf" class="site-footer__item" download>
      <Icon name="download" size={14} />
      <span>Resume</span>
    </a>
    <span class="site-footer__separator" aria-hidden="true">|</span>
    <span class="site-footer__item">
      <Icon name="map-pin" size={14} />
      <span>Based in Toronto, ON</span>
    </span>
    <span class="site-footer__separator" aria-hidden="true">|</span>
    <span class="site-footer__item">v0.1</span>
  </div>
</footer>

<style>
  @layer components {
    .site-footer {
      padding: var(--space-4) var(--space-4);
      border-top: 1px solid var(--border-subtle);
    }

    .site-footer__content {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-2);
      flex-wrap: wrap;
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--text-tertiary);
    }

    .site-footer__item {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      white-space: nowrap;
    }

    a.site-footer__item {
      color: var(--text-tertiary);
      text-decoration: none;
      transition: color 150ms ease;
    }

    a.site-footer__item:hover {
      color: var(--accent);
    }

    a.site-footer__item:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .site-footer__separator {
      color: var(--border-visible);
    }

    @media (max-width: 767px) {
      .site-footer__content {
        flex-direction: column;
        gap: var(--space-2);
      }

      .site-footer__separator {
        display: none;
      }
    }
  }
</style>
