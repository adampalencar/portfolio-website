---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'case-studies'>;
  href?: string;
  featured?: boolean;
}

const { entry, href, featured = false } = Astro.props;
const { title, oneliner, thumbnail, category, discipline, code, tier } = entry.data;
const linkTarget = href ?? `/work/${entry.id}`;
const tagLabel = `${category} / ${discipline}`.toUpperCase();

const imageSizes = featured
  ? '(max-width: 767px) 100vw, (max-width: 1199px) 100vw, 80vw'
  : '(max-width: 767px) 100vw, (max-width: 1199px) 50vw, 50vw';
---

<article class="project-card" data-tier={tier} data-featured={featured || undefined}>
  <a href={linkTarget} class="project-card__link">
    <div class="project-card__image-wrap">
      <Image
        src={thumbnail}
        alt={title}
        widths={[400, 800, 1200, 1600]}
        sizes={imageSizes}
      />
    </div>
    <div class="project-card__body">
      <span class="project-card__code">{code}</span>
      <h3 class="project-card__title">{title}</h3>
      <p class="project-card__oneliner">{oneliner}</p>
      <span class="project-card__tag">{tagLabel}</span>
    </div>
  </a>
</article>

<style>
  @layer components {
    .project-card {
      border-top: 2px solid transparent;
      transition: border-color 0.3s ease;
    }

    .project-card__link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    .project-card__link:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 4px;
      border-radius: var(--space-2);
    }

    .project-card__image-wrap {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: var(--space-2);
      background: var(--bg-secondary);
    }

    /* Featured card: wider crop so title is visible without scrolling */
    .project-card[data-featured] .project-card__image-wrap {
      aspect-ratio: 21 / 9;
    }

    .project-card__image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .project-card__body {
      padding-top: var(--space-3);
    }

    .project-card__code {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 6px;
    }

    .project-card__title {
      font-family: var(--font-body);
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--text-primary);
      margin: 0 0 8px 0;
    }

    .project-card__oneliner {
      font-size: 14px;
      color: var(--text-secondary);
      margin: 0 0 10px 0;
      line-height: var(--leading-normal);
    }

    .project-card__tag {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--accent);
    }

    /* Hover: desktop with fine pointer only */
    @media (hover: hover) and (pointer: fine) {
      .project-card:hover {
        border-top-color: var(--accent);
      }

      .project-card:hover .project-card__image-wrap img {
        transform: scale(1.03);
      }

      /* Focus parity */
      .project-card:has(:focus-visible) {
        border-top-color: var(--accent);
      }

      .project-card:has(:focus-visible) .project-card__image-wrap img {
        transform: scale(1.03);
      }
    }

    /* Mobile: tap feedback */
    @media (hover: none) {
      .project-card:active {
        transform: scale(0.98);
        transition: transform 0.1s ease;
      }
    }
  }
</style>
