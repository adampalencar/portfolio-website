---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ui/ProjectCard.astro';

const allStudies = await getCollection('case-studies');
const tier1 = allStudies
  .filter(s => s.data.tier === 1)
  .sort((a, b) => {
    const order = ['orbital-concierge', 'krom', 'pipeline'];
    return order.indexOf(a.id) - order.indexOf(b.id);
  });
---

<BaseLayout title="Adam Palencar - UI/UX Designer" description="Portfolio of Adam Palencar, UI/UX Designer. Games, tools, and interactive products.">

  <!-- Hero -->
  <section class="hero">
    <span class="hero__mark hero__mark--tl">+</span>
    <span class="hero__mark hero__mark--tr">+</span>
    <span class="hero__mark hero__mark--br">+</span>
    <div class="hero__content">
      <p class="hero__eyebrow">UI/UX DESIGNER, TORONTO · FIGMA · UNREAL ENGINE 5 · GAME UI</p>
      <h1 class="hero__name"><span class="hero__name--first">Adam</span> Palencar</h1>
      <p class="hero__statement">I design interfaces that earn their complexity. Games, tools, and interactive products where clarity and craft have to coexist.</p>
      <a href="/work" class="btn-primary" style="color:#fff">View my work</a>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="featured">
    <div class="section-marker">
      <span class="section-marker__num">01</span>
      <span class="section-marker__slash">/</span>
      <span class="section-marker__title">FEATURED WORK</span>
      <span class="section-marker__line"></span>
    </div>

    {tier1[0] && <ProjectCard entry={tier1[0]} featured />}

    <div class="featured__row">
      {tier1[1] && <ProjectCard entry={tier1[1]} href="/work#krom" />}
      {tier1[2] && <ProjectCard entry={tier1[2]} href="/work#pipeline" />}
    </div>

    <a href="/work" class="featured__cta">
      <span>SEE ALL PROJECTS</span>
      <span class="featured__cta-arrow">&rarr;</span>
    </a>
  </section>

  <!-- Intro / About -->
  <section class="intro">
    <div class="intro__inner">
      <div class="section-marker">
        <span class="section-marker__num">02</span>
        <span class="section-marker__slash">/</span>
        <span class="section-marker__title">ABOUT</span>
        <span class="section-marker__line"></span>
      </div>

      <h2 class="intro__heading">Sound editor turned UI/UX designer.</h2>
      <p class="intro__body">I edited audio and video for years. The part that stuck with me wasn't the media, it was the structure: how information gets organized, how timing changes whether someone follows along or checks out. Now I design interfaces where those instincts matter.</p>
      <p class="intro__exp">Currently based in Toronto. Previously at Floppy Goat (game UI), freelance (audio/video), and Lotus Pictures (NYC).</p>
      <a href="/about" class="btn-outline">More about me</a>
    </div>
  </section>

  <!-- Contact Strip -->
  <section id="contact" class="contact-wrap">
    <div class="contact-strip">
      <h2 class="contact-strip__heading">Looking for work.</h2>
      <p class="contact-strip__body">I'm open to UI/UX roles in games, product design, and interactive tools. If you're hiring or want to talk, reach out.</p>
      <div class="contact-strip__links">
        <a href="mailto:adampalencar25@gmail.com" class="contact-strip__email">adampalencar25@gmail.com</a>
        <span class="contact-strip__dot">&middot;</span>
        <a href="https://linkedin.com/in/adampalencar" target="_blank" rel="noopener noreferrer" class="contact-strip__link">LINKEDIN</a>
        <span class="contact-strip__dot">&middot;</span>
        <!-- TODO: Replace placeholder PDF with real resume -->
        <a href="/resume/adam-palencar-resume.pdf" download class="contact-strip__link">RESUME</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @layer components {
    /* --- Hero --- */
    .hero {
      position: relative;
      padding: var(--space-7) 96px var(--space-6) 96px;
    }

    .hero__mark {
      position: absolute;
      font-family: var(--font-mono);
      font-size: 14px;
      color: rgba(26, 26, 26, 0.05);
      user-select: none;
    }

    .hero__mark--tl { top: 48px; left: 48px; }
    .hero__mark--tr { top: 48px; right: 48px; }
    .hero__mark--br { bottom: 48px; right: 48px; }

    [data-theme="dark"] .hero__mark {
      color: rgba(240, 237, 230, 0.05);
    }

    .hero__content {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .hero__eyebrow {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--text-tertiary);
      margin: 0;
    }

    .hero__name {
      font-family: var(--font-body);
      font-size: 96px;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 0.9;
      color: var(--text-primary);
      margin: 0;
    }

    .hero__name--first {
      color: var(--accent);
    }

    .hero__statement {
      font-size: 20px;
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      max-width: 618px;
      margin: 0;
    }

    /* Section marker spacing (structure in global.css) */
    .section-marker {
      margin-bottom: var(--space-5);
    }

    /* --- Featured Work --- */
    .featured {
      padding: var(--space-7) 96px;
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .featured__row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }

    .featured__cta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      text-decoration: none;
      color: var(--text-secondary);
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      padding-top: var(--space-3);
    }

    .featured__cta:hover {
      color: var(--text-primary);
    }

    .featured__cta-arrow {
      font-size: 16px;
    }

    /* --- Intro --- */
    .intro {
      background: var(--bg-secondary);
      padding: var(--space-7) 96px;
    }

    .intro__inner {
      max-width: 680px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .intro__heading {
      font-family: var(--font-body);
      font-size: 36px;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: var(--leading-tight);
      color: var(--text-primary);
      margin: 0;
    }

    .intro__body {
      font-size: var(--size-base);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      margin: 0;
    }

    .intro__exp {
      font-size: 14px;
      line-height: var(--leading-normal);
      color: var(--text-tertiary);
      margin: 0;
    }

    /* --- Contact Strip (always dark, theme-independent) --- */
    .contact-wrap {
      padding: var(--space-6) 96px var(--space-5) 96px;
    }

    .contact-strip {
      background: #1A1A1A;
      border-radius: var(--space-2);
      padding: var(--space-6) var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .contact-strip__heading {
      font-family: var(--font-body);
      font-size: 28px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: #FFFFFF;
      margin: 0;
    }

    .contact-strip__body {
      font-size: var(--size-base);
      line-height: var(--leading-relaxed);
      color: #999999;
      max-width: 600px;
      margin: 0;
    }

    .contact-strip__links {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
    }

    .contact-strip__email {
      color: #1B7A3D;
      text-decoration: none;
      letter-spacing: 0.05em;
    }

    .contact-strip__email:hover {
      text-decoration: underline;
      color: #1B7A3D;
    }

    .contact-strip__dot {
      color: #666666;
    }

    .contact-strip__link {
      color: #999999;
      text-decoration: none;
      letter-spacing: 0.1em;
    }

    .contact-strip__link:hover {
      color: #FFFFFF;
    }

    /* --- Responsive --- */
    @media (max-width: 1199px) {
      .hero {
        padding: var(--space-6) var(--grid-gutter);
      }

      .hero__name {
        font-size: 64px;
      }

      .hero__mark { display: none; }

      .featured {
        padding: var(--space-6) var(--grid-gutter);
      }

      .intro {
        padding: var(--space-6) var(--grid-gutter);
      }

      .contact-wrap {
        padding: var(--space-6) var(--grid-gutter);
      }
    }

    @media (max-width: 767px) {
      .hero__name {
        font-size: 48px;
      }

      .hero__statement {
        font-size: var(--size-base);
      }

      .featured__row {
        grid-template-columns: 1fr;
      }

      .intro__heading {
        font-size: 28px;
      }

      .contact-strip {
        padding: var(--space-4);
      }

      .contact-strip__links {
        flex-wrap: wrap;
      }
    }
  }
</style>
