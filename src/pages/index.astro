---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const allStudies = await getCollection('case-studies');
const tier1 = allStudies
  .filter(s => s.data.tier === 1)
  .sort((a, b) => {
    const order = ['orbital-concierge', 'krom', 'crate-digging'];
    return order.indexOf(a.id) - order.indexOf(b.id);
  });
---

<BaseLayout title="Adam Palencar - UI/UX Designer" description="Portfolio of Adam Palencar, UI/UX Designer. Interactive products, tools, and digital experiences.">

  <!-- Hero -->
  <section class="hero" data-reveal>
    <span class="hero__mark hero__mark--tl">+</span>
    <span class="hero__mark hero__mark--tr">+</span>
    <span class="hero__mark hero__mark--br">+</span>
    <div class="hero__content">
      <p class="hero__eyebrow">UI/UX DESIGNER, TORONTO · FIGMA · INTERACTIVE PRODUCTS</p>
      <h1 class="hero__name"><span class="hero__name--first">Adam</span> <span class="hero__surname" title="Pronounced: Pal-en-char"><span class="hero__surname-slot"><span class="hero__surname-real">Palenčár</span><span class="hero__surname-pron" aria-hidden="true">Pal‑en‑char</span></span></span></h1>
      <p class="hero__statement">I design interfaces that earn their complexity. Games, tools, and interactive products where clarity and craft have to coexist.</p>
      <a href="/work" class="btn-primary" style="color:#fff">View my work</a>
    </div>
    <div class="hero__visual" aria-hidden="true">
      <canvas class="hero__dots"></canvas>
    </div>
    <div class="hero__scroll" aria-hidden="true">
      <span class="hero__scroll-label">SCROLL</span>
      <span class="hero__scroll-arrow">&darr;</span>
    </div>
  </section>

  <!-- Featured Work -->
  <section class="featured" data-reveal style="--reveal-delay: 1">
    <div class="section-marker">
      <span class="section-marker__title">SELECTED WORK</span>
      <span class="section-marker__line"></span>
    </div>

    <div class="carousel" aria-label="Featured projects" role="region">
      <div class="carousel__stage">
        {tier1.map((entry, i) => {
          const { title, thumbnail, code } = entry.data;
          const pos = i === 0 ? 'center' : i === 1 ? 'right' : 'left';
          return (
            <a
              href={`/work/${entry.id}`}
              class="carousel__card"
              data-position={pos}
              data-index={i}
              aria-label={title}
            >
              <Image
                src={thumbnail}
                alt={title}
                widths={[400, 800, 1200]}
                sizes="(max-width: 767px) 90vw, 600px"
              />
            </a>
          );
        })}
      </div>

      <div class="carousel__info" aria-live="polite">
        {tier1.map((entry, i) => {
          const { title, oneliner, category, discipline, code } = entry.data;
          return (
            <div class:list={['carousel__info-slide', { 'carousel__info-slide--active': i === 0 }]} data-info-index={i}>
              <span class="carousel__info-code">{code}</span>
              <h3 class="carousel__info-title">{title}</h3>
              <p class="carousel__info-desc">{oneliner}</p>
              <span class="carousel__info-tag">{`${category} / ${discipline}`.toUpperCase()}</span>
              <a href={`/work/${entry.id}`} class="carousel__info-cta">VIEW PROJECT &rarr;</a>
            </div>
          );
        })}
      </div>

      <div class="carousel__nav">
        <div class="carousel__nav-left">
          <span class="carousel__counter"><span class="carousel__counter-current">01</span> / <span class="carousel__counter-total">03</span></span>
          <div class="carousel__progress">
            <div class="carousel__progress-fill"></div>
          </div>
        </div>
        <a href="/work" class="carousel__all-link">SEE ALL PROJECTS</a>
        <div class="carousel__arrows">
          <button class="carousel__arrow carousel__arrow--prev" aria-label="Previous project">&larr;</button>
          <button class="carousel__arrow carousel__arrow--next" aria-label="Next project">&rarr;</button>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro / About -->
  <section class="intro" data-reveal style="--reveal-delay: 0">
    <div class="intro__inner">
      <div class="section-marker intro__marker">
        <span class="section-marker__title">ABOUT</span>
        <span class="section-marker__line"></span>
      </div>

      <div class="intro__left">
        <h2 class="intro__heading"><span class="intro__accent">Sound</span> editor turned UI/UX designer.</h2>
        <p class="intro__body">I edited audio and video for years. The part that stuck with me wasn't the media, it was the structure: how information gets organized, how timing changes whether someone follows along or checks out. Now I design interfaces where those instincts matter.</p>
      </div>
      <div class="intro__right">
        <p class="intro__exp">Currently based in Toronto. Previously at Floppy Goat (UI/UX), freelance (audio/video), and Lotus Pictures (NYC).</p>
        <a href="/about" class="btn-outline">More about me</a>
      </div>
    </div>
  </section>

  <!-- Contact Strip -->
  <section id="contact" class="contact-strip" data-reveal style="--reveal-delay: 0">
    <div class="contact-strip__inner">
      <h2 class="contact-strip__heading">Looking for work.</h2>
      <p class="contact-strip__body">I'm open to UI/UX roles in product design, interactive experiences, and digital tools. If you're hiring or want to talk, reach out.</p>
      <div class="contact-strip__links">
        <a href="mailto:adampalencar25@gmail.com" class="contact-strip__email">adampalencar25@gmail.com</a>
        <span class="contact-strip__dot">&middot;</span>
        <a href="https://linkedin.com/in/adampalencar" target="_blank" rel="noopener noreferrer" class="contact-strip__link">LINKEDIN</a>
        <span class="contact-strip__dot">&middot;</span>
        <!-- TODO: Replace placeholder PDF with real resume -->
        <a href="/resume/adam-palencar-resume.pdf" download class="contact-strip__link">RESUME</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  @layer components {
    /* --- Hero --- */
    .hero {
      position: relative;
      padding: var(--space-9) 96px var(--space-8) 96px;
      min-height: 85vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .hero__mark {
      position: absolute;
      font-family: var(--font-mono);
      font-size: 20px;
      color: rgba(26, 26, 26, 0.08);
      user-select: none;
    }

    .hero__mark--tl { top: 48px; left: 48px; }
    .hero__mark--tr { top: 48px; right: 48px; }
    .hero__mark--br { bottom: 48px; right: 48px; }

    [data-theme="dark"] .hero__mark {
      color: rgba(240, 237, 230, 0.06);
    }

    .hero__content {
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .hero__eyebrow {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--text-tertiary);
      margin: 0;
    }

    .hero__name {
      font-family: var(--font-display), var(--font-body), system-ui, sans-serif;
      font-size: 96px;
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 0.9;
      color: var(--text-primary);
      margin: 0;
      view-transition-name: page-title;
      /* Force GPU rendering: switches Windows from ClearType (subpixel) to
         grayscale antialiasing, fixing color fringing on thin diacritical marks */
      backface-visibility: hidden;
    }

    .hero__name--first {
      color: var(--accent);
    }

    /* --- Surname: squiggle + split-flap hover --- */
    .hero__surname {
      position: relative;
      display: block;
      cursor: help;
    }

    /* Squiggle: invisible duplicate text carries the wavy decoration */
    .hero__surname::after {
      content: 'Palenčár';
      position: absolute;
      left: 0;
      bottom: 0;
      color: transparent;
      font-size: inherit;
      font-weight: inherit;
      font-family: inherit;
      letter-spacing: inherit;
      text-decoration: underline wavy #d93025;
      text-decoration-thickness: 2px;
      text-underline-offset: 4px;
      pointer-events: none;
      transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1),
                  opacity 0.15s ease;
    }

    .hero__surname:hover::after {
      opacity: 0;
      transform: translateY(-100%);
    }

    /* Slot machine container */
    .hero__surname-slot {
      display: inline-grid;
      overflow: hidden;
      padding-top: 10px;
      margin-top: -10px;
      padding-bottom: 20px;
      margin-bottom: -20px;
    }

    .hero__surname-real,
    .hero__surname-pron {
      grid-area: 1 / 1;
      white-space: nowrap;
      transition: transform 0.3s cubic-bezier(0.23, 1, 0.32, 1),
                  opacity 0.15s ease;
    }

    .hero__surname-pron {
      text-decoration: none;
    }

    .hero__surname-pron {
      opacity: 0;
      transform: translateY(100%);
    }

    .hero__surname:hover .hero__surname-real {
      opacity: 0;
      transform: translateY(-100%);
    }

    .hero__surname:hover .hero__surname-pron {
      opacity: 1;
      transform: translateY(0);
    }

    .hero__statement {
      font-size: 20px;
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      max-width: 618px;
      margin: 0;
    }

    .hero__visual {
      align-self: stretch;
      position: relative;
      -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
      mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
    }

    .hero__dots {
      display: block;
      width: 100%;
      height: 100%;
    }

    /* Section marker spacing (structure in global.css) */
    .section-marker {
      margin-bottom: var(--space-5);
    }

    /* --- Featured Work --- */
    .featured {
      padding: var(--space-6) 96px var(--space-9);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    /* --- Carousel --- */
    .carousel {
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    .carousel__stage {
      position: relative;
      height: 440px;
      overflow: hidden;
    }

    .carousel__card {
      position: absolute;
      display: block;
      width: 680px;
      height: 383px;
      top: 50%;
      left: 50%;
      border-radius: 12px;
      overflow: hidden;
      background: var(--bg-card);
      text-decoration: none;
      transition:
        transform 500ms cubic-bezier(0.23, 1, 0.32, 1),
        opacity 400ms cubic-bezier(0.23, 1, 0.32, 1);
    }

    .carousel__card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .carousel__card:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 4px;
      border-radius: 12px;
    }

    /* Center (active) */
    .carousel__card[data-position="center"] {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
      z-index: 3;
      box-shadow:
        0 2px 8px rgba(0, 0, 0, 0.06),
        0 12px 32px rgba(0, 0, 0, 0.08);
    }

    .carousel__card[data-position="center"]:hover {
      transform: translate(-50%, -50%) scale(1.02);
    }

    /* Right peek */
    .carousel__card[data-position="right"] {
      transform: translate(-50%, -50%) translateX(62%) scale(0.82);
      opacity: 0.5;
      z-index: 1;
      box-shadow: none;
    }

    /* Left peek */
    .carousel__card[data-position="left"] {
      transform: translate(-50%, -50%) translateX(-62%) scale(0.82);
      opacity: 0.5;
      z-index: 1;
      box-shadow: none;
    }

    /* Hidden (off-screen for > 3 cards) */
    .carousel__card[data-position="hidden"] {
      transform: translate(-50%, -50%) scale(0.7);
      opacity: 0;
      z-index: 0;
      pointer-events: none;
    }

    /* --- Carousel Info --- */
    .carousel__info {
      position: relative;
      min-height: 220px;
    }

    .carousel__info-slide {
      position: absolute;
      top: 0;
      left: 0;
      opacity: 0;
      transition: opacity 0.4s ease;
      pointer-events: none;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .carousel__info-slide--active {
      opacity: 1;
      position: relative;
      pointer-events: auto;
    }

    .carousel__info-code {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--accent-text);
    }

    .carousel__info-title {
      font-family: var(--font-body);
      font-size: 42px;
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: var(--leading-tight);
      color: var(--text-primary);
      margin: 0;
    }

    .carousel__info-desc {
      font-size: 14px;
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0;
    }

    .carousel__info-tag {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--accent-text);
    }

    .carousel__info-cta {
      align-self: flex-start;
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 600;
      letter-spacing: 0.08em;
      color: var(--accent-text);
      text-decoration: none;
      padding: 8px 16px;
      border: 1px solid var(--accent);
      border-radius: 4px;
      transition: background 0.2s ease, color 0.2s ease;
    }

    .carousel__info-cta:hover {
      background: var(--accent);
      color: #fff;
    }

    /* --- Carousel Nav (unified bar) --- */
    .carousel__nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-top: var(--space-2);
    }

    .carousel__nav-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .carousel__counter {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--text-tertiary);
    }

    .carousel__counter-current {
      color: var(--text-primary);
    }

    .carousel__progress {
      width: 120px;
      height: 2px;
      background: var(--border-visible);
      border-radius: 1px;
    }

    .carousel__progress-fill {
      height: 100%;
      width: 100%;
      background: var(--accent);
      border-radius: 1px;
      transform: scaleX(0.3333);
      transform-origin: left;
      transition: transform 0.4s ease;
    }

    .carousel__all-link {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--text-tertiary);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .carousel__all-link:hover {
      color: var(--text-primary);
    }

    .carousel__arrows {
      display: flex;
      gap: 8px;
    }

    .carousel__arrow {
      width: 44px;
      height: 44px;
      border-radius: 8px;
      border: 1px solid var(--border-visible);
      background: transparent;
      color: var(--text-tertiary);
      font-size: 16px;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    }

    .carousel__arrow:hover {
      border-color: var(--text-secondary);
      color: var(--text-primary);
    }

    .carousel__arrow:active {
      transform: scale(0.95);
    }

    .carousel__arrow:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .carousel__all-link:focus-visible,
    .carousel__info-cta:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 4px;
    }

    .carousel__arrow--next {
      background: var(--accent);
      border-color: var(--accent);
      color: #fff;
    }

    .carousel__arrow--next:hover {
      background: var(--accent-hover);
      border-color: var(--accent-hover);
      color: #fff;
    }

    /* --- Intro --- */
    .intro {
      background: var(--bg-secondary);
      padding: var(--space-7) 96px var(--space-9);
    }

    .intro__inner {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      column-gap: var(--space-7);
      row-gap: var(--space-4);
      align-items: start;
    }

    .intro__marker {
      grid-column: 1 / -1;
    }

    .intro__left {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .intro__right {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding-top: var(--space-2);
    }

    .intro__heading {
      font-family: var(--font-body);
      font-size: 48px;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: var(--leading-tight);
      color: var(--text-primary);
      margin: 0;
    }

    .intro__accent {
      color: var(--accent-text);
    }

    .intro__body {
      font-size: var(--size-base);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      margin: 0;
    }

    .intro__exp {
      font-size: 14px;
      line-height: var(--leading-normal);
      color: var(--text-tertiary);
      margin: 0;
    }

    /* --- Contact Strip (full-width dark section, theme-independent) --- */
    .contact-strip {
      background: var(--bg-primary);
      padding: var(--space-7) 96px;
      border-top: 1px solid var(--border-subtle);
    }

    .contact-strip__inner {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .contact-strip__heading {
      font-family: var(--font-body);
      font-size: 28px;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin: 0;
    }

    .contact-strip__body {
      font-size: var(--size-base);
      line-height: var(--leading-relaxed);
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0;
    }

    .contact-strip__links {
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--font-mono);
      font-size: 12px;
      font-weight: 500;
      margin-top: var(--space-2);
    }

    .contact-strip__email {
      color: var(--accent-text);
      text-decoration: none;
      letter-spacing: 0.05em;
    }

    .contact-strip__email:hover {
      text-decoration: underline;
      color: var(--accent-hover);
    }

    .contact-strip__dot {
      color: var(--text-tertiary);
    }

    .contact-strip__link {
      color: var(--text-tertiary);
      text-decoration: none;
      letter-spacing: 0.1em;
    }

    .contact-strip__link:hover {
      color: var(--text-primary);
    }

    /* --- Scroll indicator: monospace label + bouncing arrow --- */
    .hero__scroll {
      position: absolute;
      bottom: 32px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      opacity: 1;
      transition: opacity 0.5s ease;
    }

    .hero__scroll.is-hidden {
      opacity: 0;
      pointer-events: none;
    }

    .hero__scroll-label {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.14em;
      color: var(--text-tertiary);
    }

    .hero__scroll-arrow {
      font-size: 16px;
      color: var(--text-tertiary);
      animation: scroll-bounce 1.8s ease-in-out infinite;
    }

    @keyframes scroll-bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(6px); }
    }

    /* --- Responsive --- */
    @media (max-width: 1199px) {
      .hero {
        padding: var(--space-7) var(--grid-gutter);
        min-height: 70vh;
        grid-template-columns: 1fr;
      }

      .hero__visual {
        display: none;
      }

      .hero__name {
        font-size: 64px;
      }

      .hero__mark { display: none; }

      .featured {
        padding: var(--space-5) var(--grid-gutter) var(--space-6);
      }

      .carousel__stage {
        height: 300px;
      }

      .carousel__card {
        width: 460px;
        height: 259px;
      }

      .carousel__info-title {
        font-size: 36px;
      }

      .intro {
        padding: var(--space-7) var(--grid-gutter);
      }

      .contact-strip {
        padding: var(--space-7) var(--grid-gutter);
      }
    }

    @media (max-width: 767px) {
      .hero__name {
        font-size: 48px;
      }

      .hero__statement {
        font-size: var(--size-base);
      }

      .intro__inner {
        grid-template-columns: 1fr;
        gap: var(--space-4);
      }

      .intro__right {
        padding-top: 0;
      }

      .carousel__stage {
        height: 220px;
      }

      .carousel__card {
        width: 300px;
        height: 169px;
      }

      .carousel__info-title {
        font-size: 28px;
      }

      .carousel__info-desc {
        font-size: 14px;
      }

      .carousel__progress {
        display: none;
      }

      .intro__heading {
        font-size: 32px;
      }

      .contact-strip {
        padding: var(--space-6) var(--grid-gutter);
      }

      .contact-strip__heading {
        font-size: 24px;
      }

      .contact-strip__links {
        flex-wrap: wrap;
      }
    }
  }
</style>

<script>
  let homepageCleanup: (() => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    const cards = [...document.querySelectorAll('.carousel__card')];
    const infoSlides = [...document.querySelectorAll('.carousel__info-slide')];
    const counterCurrent = document.querySelector('.carousel__counter-current');
    const progressFill = document.querySelector('.carousel__progress-fill') as HTMLElement | null;
    const prevBtn = document.querySelector('.carousel__arrow--prev');
    const nextBtn = document.querySelector('.carousel__arrow--next');
    const carousel = document.querySelector('.carousel');

    const cleanups: (() => void)[] = [];

    // Scroll indicator: show at top, hide when scrolled
    const scrollIndicator = document.querySelector('.hero__scroll');
    if (scrollIndicator) {
      const updateScroll = () => {
        scrollIndicator.classList.toggle('is-hidden', window.scrollY > 80);
      };
      updateScroll();
      window.addEventListener('scroll', updateScroll, { passive: true });
      cleanups.push(() => window.removeEventListener('scroll', updateScroll));
    }

    if (!cards.length || !carousel) {
      homepageCleanup = cleanups.length ? () => cleanups.forEach(fn => fn()) : null;
      return;
    }

    const total = cards.length;
    let active = 0;
    let isAnimating = false;
    let debounceTimer: ReturnType<typeof setTimeout> | null = null;

    function update() {
      const prev = (active - 1 + total) % total;
      const next = (active + 1) % total;

      cards.forEach((card, i) => {
        if (i === active) card.dataset.position = 'center';
        else if (i === next) card.dataset.position = 'right';
        else if (i === prev) card.dataset.position = 'left';
        else card.dataset.position = 'hidden';
      });

      infoSlides.forEach((slide, i) => {
        slide.classList.toggle('carousel__info-slide--active', i === active);
      });

      counterCurrent!.textContent = String(active + 1).padStart(2, '0');
      if (progressFill) {
        progressFill.style.transform = `scaleX(${(active + 1) / total})`;
      }

      isAnimating = true;
      if (debounceTimer) clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => { isAnimating = false; }, 500);
    }

    // Set initial state
    update();

    function goNext() { if (!isAnimating) { active = (active + 1) % total; update(); } }
    function goPrev() { if (!isAnimating) { active = (active - 1 + total) % total; update(); } }

    nextBtn!.addEventListener('click', goNext);
    prevBtn!.addEventListener('click', goPrev);

    // Keyboard nav
    carousel.setAttribute('tabindex', '0');
    carousel.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'ArrowRight') { e.preventDefault(); goNext(); }
      if ((e as KeyboardEvent).key === 'ArrowLeft') { e.preventDefault(); goPrev(); }
    });

    // Touch swipe
    let touchStartX = 0;
    const stage = document.querySelector('.carousel__stage');
    stage!.addEventListener('touchstart', (e) => { touchStartX = (e as TouchEvent).touches[0].clientX; }, { passive: true });
    stage!.addEventListener('touchend', (e) => {
      const diff = touchStartX - (e as TouchEvent).changedTouches[0].clientX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goNext();
        else goPrev();
      }
    });

    // Click side cards to navigate
    cards.forEach(card => {
      card.addEventListener('click', (e) => {
        const pos = card.dataset.position;
        if (pos === 'left') { e.preventDefault(); goPrev(); }
        else if (pos === 'right') { e.preventDefault(); goNext(); }
      });
    });

    cleanups.push(() => {
      if (debounceTimer) clearTimeout(debounceTimer);
    });

    homepageCleanup = () => cleanups.forEach(fn => fn());
  });

  document.addEventListener('astro:before-swap', () => {
    if (homepageCleanup) {
      homepageCleanup();
      homepageCleanup = null;
    }
  });
</script>

<script>
  let dotsCleanup: (() => void) | null = null;

  document.addEventListener('astro:page-load', () => {
    const canvas = document.querySelector('.hero__dots');
    if (!canvas || !(canvas instanceof HTMLCanvasElement)) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const container = canvas.parentElement!;
    const SPACING = 28;
    const BASE_R = 1.2;
    const PROXIMITY = 120;

    let mouse = { x: -1000, y: -1000 };
    let dots: { x: number; y: number }[] = [];
    let pending = false;
    let dpr = window.devicePixelRatio || 1;

    function resize() {
      dpr = window.devicePixelRatio || 1;
      const rect = container.getBoundingClientRect();
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx!.setTransform(dpr, 0, 0, dpr, 0, 0);
      buildGrid(rect.width, rect.height);
      draw();
    }

    function buildGrid(w: number, h: number) {
      dots = [];
      const cols = Math.floor(w / SPACING);
      const rows = Math.floor(h / SPACING);
      const ox = (w - (cols - 1) * SPACING) / 2;
      const oy = (h - (rows - 1) * SPACING) / 2;
      for (let r = 0; r < rows; r++) {
        for (let c = 0; c < cols; c++) {
          dots.push({ x: ox + c * SPACING, y: oy + r * SPACING });
        }
      }
    }

    function draw() {
      const w = canvas.width / dpr;
      const h = canvas.height / dpr;
      ctx!.clearRect(0, 0, w, h);

      const isDark = document.documentElement.dataset.theme === 'dark';
      const baseRgb = isDark ? '240,237,230' : '26,26,26';
      const accentRgb = isDark ? '74,158,104' : '27,122,61';
      const baseAlpha = isDark ? 0.07 : 0.05;

      for (const dot of dots) {
        const dx = dot.x - mouse.x;
        const dy = dot.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        let alpha = baseAlpha;
        let radius = BASE_R;
        let rgb = baseRgb;

        if (dist < PROXIMITY) {
          const t = 1 - dist / PROXIMITY;
          const ease = t * t;
          alpha = baseAlpha + ease * 0.3;
          radius = BASE_R + ease * 2;
          if (ease > 0.5) rgb = accentRgb;
        }

        ctx!.beginPath();
        ctx!.arc(dot.x, dot.y, radius, 0, 6.2832);
        ctx!.fillStyle = `rgba(${rgb},${alpha})`;
        ctx!.fill();
      }
      pending = false;
    }

    function scheduleDraw() {
      if (!pending) {
        pending = true;
        requestAnimationFrame(draw);
      }
    }

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function onMouseMove(e: MouseEvent) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
      scheduleDraw();
    }

    function onMouseLeave() {
      mouse.x = -1000;
      mouse.y = -1000;
      scheduleDraw();
    }

    if (!reducedMotion) {
      container.addEventListener('mousemove', onMouseMove);
      container.addEventListener('mouseleave', onMouseLeave);
    }

    resize();
    window.addEventListener('resize', resize);

    dotsCleanup = () => {
      window.removeEventListener('resize', resize);
      container.removeEventListener('mousemove', onMouseMove);
      container.removeEventListener('mouseleave', onMouseLeave);
    };
  });

  document.addEventListener('astro:before-swap', () => {
    if (dotsCleanup) {
      dotsCleanup();
      dotsCleanup = null;
    }
  });
</script>
