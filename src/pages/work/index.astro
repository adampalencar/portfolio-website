---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allStudies = await getCollection('case-studies');
const sorted = allStudies.sort((a, b) => {
  const order = ['orbital-concierge', 'krom', 'pipeline'];
  const aIdx = order.indexOf(a.id);
  const bIdx = order.indexOf(b.id);
  if (aIdx !== -1 && bIdx !== -1) return aIdx - bIdx;
  if (aIdx !== -1) return -1;
  if (bIdx !== -1) return 1;
  return a.data.tier - b.data.tier || a.id.localeCompare(b.id);
});

const hasFullStudy = (entry: typeof sorted[0]) =>
  entry.body && entry.body.trim().length > 50;
---

<BaseLayout title="Work - Adam Palencar" description="Selected projects in game UI, product design, and interactive tools.">

  <div class="work-page">
    <header class="work-page__header">
      <h1 class="work-page__title">Work</h1>
      <p class="work-page__subtitle">Selected projects in game UI, product design, and interactive tools.</p>
    </header>

    <div class="section-marker">
      <span class="section-marker__num">01</span>
      <span class="section-marker__slash">/</span>
      <span class="section-marker__title">ALL PROJECTS</span>
      <span class="section-marker__line"></span>
    </div>

    <div class="work-grid">
      {sorted.map((entry, i) => {
        const ready = hasFullStudy(entry);
        const tagLabel = `${entry.data.category} / ${entry.data.discipline}`.toUpperCase();

        return ready ? (
          <a
            href={`/work/${entry.id}`}
            class="work-card"
            id={entry.id}
            data-reveal
            style={`--reveal-delay: ${i}`}
          >
            <div class="work-card__image-wrap">
              <Image
                src={entry.data.thumbnail}
                alt={entry.data.title}
                widths={[400, 800, 1200, 1600]}
                sizes="(max-width: 767px) 100vw, 50vw"
              />
            </div>
            <div class="work-card__body">
              <span class="work-card__code">{entry.data.code}</span>
              <h3 class="work-card__title">{entry.data.title}</h3>
              <p class="work-card__desc">{entry.data.oneliner}</p>
              <div class="work-card__footer">
                <span class="work-card__tag">{tagLabel}</span>
                <span class="work-card__cta">View case study &rarr;</span>
              </div>
            </div>
          </a>
        ) : (
          <div
            class="work-card"
            id={entry.id}
            data-status="upcoming"
            data-reveal
            style={`--reveal-delay: ${i}`}
          >
            <div class="work-card__image-wrap">
              <Image
                src={entry.data.thumbnail}
                alt={entry.data.title}
                widths={[400, 800, 1200]}
                sizes="(max-width: 767px) 100vw, 50vw"
              />
            </div>
            <div class="work-card__body">
              <span class="work-card__code">{entry.data.code}</span>
              <h3 class="work-card__title">{entry.data.title}</h3>
              <p class="work-card__desc">{entry.data.oneliner}</p>
              <div class="work-card__footer">
                <span class="work-card__tag">{tagLabel}</span>
                <span class="work-card__status">CASE STUDY IN PROGRESS</span>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>

</BaseLayout>

<style>
  @layer components {
    .work-page {
      padding: var(--space-7) 96px var(--space-8);
      display: flex;
      flex-direction: column;
      gap: var(--space-5);
    }

    /* --- Header --- */
    .work-page__header {
      margin-bottom: var(--space-3);
    }

    .work-page__title {
      font-size: 48px;
      font-weight: 700;
      letter-spacing: -0.02em;
      margin: 0 0 var(--space-2) 0;
    }

    .work-page__subtitle {
      font-size: var(--size-base);
      color: var(--text-secondary);
      margin: 0;
    }

    /* --- Grid --- */
    .work-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-5);
    }

    /* --- Card base --- */
    .work-card {
      display: block;
      text-decoration: none;
      color: inherit;
      border-top: 2px solid transparent;
      transition: border-color 0.3s ease;
    }

    a.work-card:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 4px;
      border-radius: var(--space-2);
    }

    /* --- Card image --- */
    .work-card__image-wrap {
      overflow: hidden;
      border-radius: var(--space-2);
      background: var(--bg-secondary);
      aspect-ratio: 16 / 9;
    }

    .work-card__image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    /* --- Card body --- */
    .work-card__body {
      padding-top: var(--space-3);
    }

    .work-card__code {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.1em;
      color: var(--accent);
      margin-bottom: 6px;
    }

    .work-card__title {
      font-family: var(--font-body);
      font-size: 22px;
      font-weight: 600;
      letter-spacing: -0.01em;
      color: var(--text-primary);
      margin: 0 0 8px 0;
    }

    .work-card__desc {
      font-size: 14px;
      color: var(--text-secondary);
      margin: 0 0 12px 0;
      line-height: var(--leading-normal);
    }

    .work-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .work-card__tag {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.1em;
      color: var(--accent);
    }

    .work-card__cta {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.05em;
      color: var(--text-secondary);
      opacity: 0;
      transform: translateY(4px);
      transition: opacity 0.3s ease, transform 0.3s ease, color 0.3s ease;
    }

    .work-card__status {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.08em;
      color: var(--text-tertiary);
    }

    /* --- Hover: desktop with fine pointer only --- */
    @media (hover: hover) and (pointer: fine) {
      a.work-card:hover {
        border-top-color: var(--accent);
      }

      a.work-card:hover .work-card__image-wrap img {
        transform: scale(1.03);
      }

      a.work-card:hover .work-card__cta {
        opacity: 1;
        transform: translateY(0);
        color: var(--accent);
      }

      /* Focus parity */
      a.work-card:focus-visible {
        border-top-color: var(--accent);
      }

      a.work-card:focus-visible .work-card__image-wrap img {
        transform: scale(1.03);
      }

      a.work-card:focus-visible .work-card__cta {
        opacity: 1;
        transform: translateY(0);
      }

      /* Upcoming cards: no hover effects */
      .work-card[data-status="upcoming"]:hover {
        border-top-color: transparent;
      }

      .work-card[data-status="upcoming"]:hover .work-card__image-wrap img {
        transform: none;
      }
    }

    /* --- Mobile: CTA always visible, tap feedback --- */
    @media (hover: none) {
      .work-card__cta {
        opacity: 1;
        transform: none;
      }

      a.work-card:active {
        transform: scale(0.98);
        transition: transform 0.1s ease;
      }
    }

    /* --- Scroll reveal --- */
    [data-reveal] {
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94),
        transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      transition-delay: calc(var(--reveal-delay, 0) * 100ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* --- Responsive --- */
    @media (max-width: 1199px) {
      .work-page {
        padding: var(--space-6) var(--grid-gutter) var(--space-8);
      }
    }

    @media (max-width: 767px) {
      .work-grid {
        grid-template-columns: 1fr;
        gap: var(--space-6);
      }

      .work-card__footer {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }
    }
  }
</style>

<script>
  function initScrollReveal() {
    const cards = document.querySelectorAll('[data-reveal]');
    if (!cards.length) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      cards.forEach(el => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -60px 0px'
    });

    cards.forEach(el => observer.observe(el));
  }

  // Run on initial load and after View Transition navigations
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
