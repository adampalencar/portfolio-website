---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - Page Not Found">
  <section class="error-page">
    <span class="error-page__code mono-label">ERROR 404</span>
    <h1 class="error-page__heading">The elevator doesn't stop at this floor.</h1>
    <p class="error-page__body">Whatever you were looking for, it's not between these walls. Try the lobby or check the directory.</p>
    <nav class="error-page__nav">
      <a class="error-page__link" href="/">Return to Lobby</a>
      <a class="error-page__link error-page__link--outline" href="/work">View the Work</a>
    </nav>
  </section>
</BaseLayout>

<style>
  @layer components {
    .error-page {
      max-width: 640px;
      margin: var(--space-8) auto;
      padding: 0 var(--grid-gutter);
      text-align: center;
    }

    .error-page__code {
      font-family: var(--font-mono);
      font-size: var(--size-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--text-tertiary);
      display: block;
      margin-bottom: var(--space-3);
    }

    .error-page__heading {
      margin-bottom: var(--space-3);
    }

    .error-page__body {
      color: var(--text-secondary);
      font-size: var(--size-lg);
      line-height: 1.6;
      margin-bottom: var(--space-5);
    }

    .error-page__nav {
      display: flex;
      gap: var(--space-3);
      justify-content: center;
    }

    .error-page__link {
      display: inline-block;
      padding: var(--space-2) var(--space-4);
      background: var(--accent);
      color: #fff;
      text-decoration: none;
      border-radius: 4px;
      font-family: var(--font-mono);
      font-size: var(--size-sm);
      letter-spacing: var(--tracking-wide);
      text-transform: uppercase;
      transition: background 0.2s ease;
    }

    .error-page__link:hover {
      background: var(--accent-hover);
    }

    .error-page__link--outline {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--accent);
    }

    .error-page__link--outline:hover {
      background: var(--accent-5);
    }
  }
</style>
