---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="404 - Page Not Found">
  <section class="error-page">
    <span class="error-page__code mono-label">ERROR 404</span>
    <h1 class="error-page__heading">The elevator doesn't stop at this floor.</h1>
    <p class="error-page__body">Whatever you were looking for, it's not between these walls. Try the lobby or check the directory.</p>
    <nav class="error-page__nav">
      <a class="btn-primary" href="/" style="color:#fff">Return to Lobby</a>
      <a class="btn-outline" href="/work">View the Work</a>
    </nav>
  </section>
</BaseLayout>

<style>
  @layer components {
    .error-page {
      max-width: 640px;
      margin: var(--space-8) auto;
      padding: 0 var(--grid-gutter);
      text-align: center;
    }

    .error-page__code {
      display: block;
      margin-bottom: var(--space-3);
    }

    .error-page__heading {
      margin-bottom: var(--space-3);
    }

    .error-page__body {
      color: var(--text-secondary);
      font-size: var(--size-lg);
      line-height: 1.6;
      margin-bottom: var(--space-5);
    }

    .error-page__nav {
      display: flex;
      gap: var(--space-3);
      justify-content: center;
    }
  }
</style>
