---
import BaseLayout from '../layouts/BaseLayout.astro';

const toolGroups = [
  {
    label: 'Design',
    tools: [
      { name: 'Figma', icon: '/icons/tools/figma.svg' },
      { name: 'FigJam', icon: '/icons/tools/figjam.svg' },
      { name: 'Miro', icon: '/icons/tools/miro.svg' },
    ],
  },
  {
    label: 'Adobe',
    tools: [
      { name: 'Photoshop', icon: '/icons/tools/photoshop.svg' },
      { name: 'Illustrator', icon: '/icons/tools/illustrator.svg' },
      { name: 'InDesign', icon: '/icons/tools/indesign.svg' },
      { name: 'Premiere Pro', icon: '/icons/tools/premierepro.svg' },
      { name: 'After Effects', icon: '/icons/tools/aftereffects.svg' },
    ],
  },
  {
    label: 'Audio',
    tools: [
      { name: 'Pro Tools', icon: '/icons/tools/protools.svg' },
      { name: 'FL Studio', icon: '/icons/tools/flstudio.svg' },
      { name: 'FMOD', icon: '/icons/tools/fmod.svg' },
    ],
  },
  {
    label: 'Code',
    tools: [
      { name: 'HTML', icon: '/icons/tools/html5.svg' },
      { name: 'CSS', icon: '/icons/tools/css3.svg' },
      { name: 'Python', icon: '/icons/tools/python.svg' },
      { name: 'Godot', icon: '/icons/tools/godot.svg' },
      { name: 'Unreal Engine', icon: '/icons/tools/unrealengine.svg' },
    ],
  },
];
---

<BaseLayout title="About - Adam Palencar" description="UI/UX Designer based in Toronto with a background in sound production and video editing.">

  <section class="about-hero" data-reveal>
    <div class="about-hero__photo">
      <div class="about-hero__initials">
        <span class="about-hero__mark about-hero__mark--tl">+</span>
        <span class="about-hero__mark about-hero__mark--br">+</span>
        AP
      </div>
    </div>
    <div class="about-hero__content">
      <h1>Adam Palenčár</h1>
      <p class="about-hero__subtitle mono-label">UI/UX Designer, Toronto</p>
      <p>I design interfaces for games and interactive products. I used to edit video and produce audio. The throughline is the same problem in different formats: how do you get someone's attention, hold it, and make sure they understand what to do next?</p>
      <p>I came to UX through sound production and video editing. Along the way I realized the thing I kept gravitating toward wasn't the media itself, it was the structure underneath: how information gets organized, how timing shapes comprehension, and at what point you've cut so much that the thing falls apart.</p>
      <p>Now I'm looking for UI/UX work in games, tools, or apps. I care about clarity and systems thinking. I also care about knowing when to stop adding things.</p>
      <p class="about-hero__availability"><strong>Available immediately. Open to remote, hybrid, or on-site in Toronto.</strong></p>
    </div>
  </section>

  <section class="about-section about-section--experience" data-reveal style="--reveal-delay: 1">
    <div class="section-marker">
      <span class="section-marker__title">EXPERIENCE</span>
      <span class="section-marker__line"></span>
    </div>
    <ol class="timeline" role="list">
      <li class="timeline__entry">
        <time class="mono-label" datetime="2025-06">2025.06 to 2025.12</time>
        <h3 class="timeline__role">UI/UX Designer</h3>
        <p class="timeline__company">Floppy Goat Inc. (Montreal, Remote)</p>
        <p class="timeline__desc">Sole designer on Isles of Krom, a dark fantasy extraction roguelike. Designed 24+ screens and a reusable component system (15+ components) in Figma for Unreal Engine 5. Built the design system, defined interaction states, and delivered annotated handoffs tight enough that developers could implement without back-and-forth.</p>
      </li>
      <li class="timeline__entry">
        <time class="mono-label" datetime="2023-02">2023.02 to 2023.11</time>
        <h3 class="timeline__role">Digital Designer and Multimedia Editor</h3>
        <p class="timeline__company">Freelance (Scotland, Remote)</p>
        <p class="timeline__desc">Created branded digital assets, edited audio and video for commercial clients, and managed production workflows across formats. Handled everything from briefs to final exports, including versioning, review cycles, and client feedback.</p>
      </li>
      <li class="timeline__entry">
        <time class="mono-label" datetime="2022-09">2022.09 to 2023.02</time>
        <h3 class="timeline__role">Video Editor Intern</h3>
        <p class="timeline__company">Lotus Pictures Inc. (New York City)</p>
        <p class="timeline__desc">Edited B2B commercial content for clients including ADP and Adobe. Organized B-roll, standardized folder structures, and streamlined review packages to speed up approval cycles.</p>
      </li>
    </ol>
  </section>

  <section class="about-section about-section--education" data-reveal style="--reveal-delay: 0">
    <div class="section-marker">
      <span class="section-marker__title">EDUCATION</span>
      <span class="section-marker__line"></span>
    </div>
    <ol class="timeline" role="list">
      <li class="timeline__entry">
        <time class="mono-label" datetime="2025-01">2025.01 to 2025.12</time>
        <h3 class="timeline__role">Graduate Certificate, User Experience Design</h3>
        <p class="timeline__company">Humber Polytechnic, Toronto</p>
        <p class="timeline__desc">Graduated with Honours</p>
      </li>
      <li class="timeline__entry">
        <time class="mono-label" datetime="2020-08">2020.08 to 2022.09</time>
        <h3 class="timeline__role">Higher National Diploma, Sound Production</h3>
        <p class="timeline__company">Forth Valley College, Stirling, Scotland</p>
      </li>
    </ol>
  </section>

  <section class="about-section about-section--approach about-section--narrow" data-reveal style="--reveal-delay: 0">
    <div class="section-marker">
      <span class="section-marker__title">APPROACH</span>
      <span class="section-marker__line"></span>
    </div>
    <p>Most UI/UX designers came to the field through graphic design or computer science. I came through sound and video production. That background shaped how I think about design:</p>
    <p>Years of editing taught me that when information appears matters as much as what the information is. A transition that's 200ms too slow feels sluggish. A tooltip that shows up before the player is ready creates noise. I think about UI pacing the way an editor thinks about a cut.</p>
    <p>Audio production is revision on revision on revision. You mix, listen back, adjust, listen again. I had thousands of hours of that cycle before I ever opened Figma, so the iteration side of design felt familiar from day one.</p>
    <p>And the hardest skill in editing, removing something you like because the piece is better without it, transfers to interface design. Every element competes for attention. The temptation is always to add more. The instinct I trust most is the one that says "take it out."</p>
  </section>

  <section class="about-section about-section--tools" data-reveal style="--reveal-delay: 0">
    <div class="section-marker">
      <span class="section-marker__title">TOOLS</span>
      <span class="section-marker__line"></span>
    </div>
    {toolGroups.map((group) => (
      <div class="tools-group">
        <span class="tools-group__label mono-label">{group.label}</span>
        <ul class="tools-grid" role="list">
          {group.tools.map((tool) => (
            <li class="tools-grid__item">
              <img src={tool.icon} alt="" width="32" height="32" class="tools-grid__icon" />
              <span class="tools-grid__name">{tool.name}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <section class="about-section about-section--personal about-section--narrow" data-reveal style="--reveal-delay: 0">
    <div class="section-marker">
      <span class="section-marker__title">PERSONAL</span>
      <span class="section-marker__line"></span>
    </div>
    <p>I compose and produce music, mostly inspired by video games. I follow indie game development closely and I'm building my own puzzle game, Orbital Concierge. I also play way too many roguelikes, collect vinyl, and occasionally try to cook something that isn't pasta.</p>
  </section>

  <section class="about-contact" data-reveal style="--reveal-delay: 0">
    <div class="section-marker">
      <span class="section-marker__title">CONTACT</span>
      <span class="section-marker__line"></span>
    </div>
    <p class="about-contact__email"><a href="mailto:adampalencar25@gmail.com">adampalencar25@gmail.com</a></p>
    <p class="about-contact__location mono-label">Toronto, ON, Canada</p>
    <div class="about-contact__links">
      <a href="https://www.linkedin.com/in/adampalencar/" class="about-contact__link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="/resume/adam-palencar-resume.pdf" class="about-contact__link">Resume</a>
    </div>
  </section>

</BaseLayout>

<style>
  @layer components {

    /* Hero */
    .about-hero {
      padding: var(--space-7) 96px var(--space-8) 96px;
      display: flex;
      gap: var(--space-7);
      align-items: flex-start;
    }

    .about-hero__photo {
      flex-shrink: 0;
    }

    .about-hero__initials {
      background: var(--bg-secondary);
      aspect-ratio: 3 / 4;
      max-width: 280px;
      width: 280px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: var(--space-2);
      font-family: var(--font-display), var(--font-body), system-ui, sans-serif;
      font-size: 80px;
      font-weight: 700;
      letter-spacing: -0.04em;
      color: var(--border-visible);
      position: relative;
      overflow: hidden;
    }

    .about-hero__mark {
      position: absolute;
      font-family: var(--font-mono);
      font-size: 14px;
      color: rgba(26, 26, 26, 0.08);
    }

    [data-theme="dark"] .about-hero__mark {
      color: rgba(240, 237, 230, 0.06);
    }

    .about-hero__mark--tl { top: 16px; left: 16px; }
    .about-hero__mark--br { bottom: 16px; right: 16px; }

    .about-hero__content {
      flex: 1;
    }

    .about-hero__content h1 {
      font-family: var(--font-display), var(--font-body), system-ui, sans-serif;
      margin-top: -4px;
      margin-bottom: var(--space-1);
    }

    .about-hero__subtitle {
      margin-bottom: var(--space-4);
    }

    .about-hero__content p {
      margin-bottom: var(--space-3);
    }

    .about-hero__content p:last-child {
      margin-bottom: 0;
    }

    .about-hero__availability {
      margin-top: var(--space-4);
    }

    @media (max-width: 1199px) {
      .about-hero,
      .about-section,
      .about-section--narrow,
      .about-contact {
        padding-left: var(--grid-gutter);
        padding-right: var(--grid-gutter);
      }

      .about-hero {
        flex-direction: column;
        align-items: center;
      }

      .about-hero__initials {
        width: 200px;
        max-width: 200px;
      }

      .about-hero__content {
        width: 100%;
      }
    }

    /* Sections with varied rhythm */
    .about-section {
      padding: var(--space-7) 96px;
    }

    .about-section--experience {
      padding-top: var(--space-7);
      padding-bottom: var(--space-7);
    }

    .about-section--education {
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }

    .about-section--approach {
      padding-top: var(--space-8);
      padding-bottom: var(--space-8);
    }

    .about-section--tools {
      padding-top: var(--space-6);
      padding-bottom: var(--space-6);
    }

    .about-section--personal {
      padding-top: var(--space-5);
      padding-bottom: var(--space-5);
    }

    .about-section--narrow p {
      max-width: 680px;
    }

    .about-section h2 {
      font-size: 36px;
      margin-bottom: var(--space-5);
    }

    .about-section .section-marker {
      margin-bottom: var(--space-5);
    }

    .about-section--narrow p {
      margin-bottom: var(--space-3);
      color: var(--text-secondary);
    }

    .about-section--narrow p:last-child {
      margin-bottom: 0;
    }

    /* Timeline */
    .timeline {
      list-style: none;
      padding-left: var(--space-6);
      position: relative;
      margin: 0;
    }

    .timeline::before {
      content: '';
      position: absolute;
      left: 7px;
      top: 8px;
      bottom: 8px;
      width: 1px;
      background: var(--border-visible);
    }

    .timeline__entry {
      position: relative;
      margin-bottom: var(--space-6);
    }

    .timeline__entry:last-child {
      margin-bottom: 0;
    }

    .timeline__entry::before {
      content: '';
      position: absolute;
      left: calc(-1 * var(--space-6) + 3px);
      top: 6px;
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--accent);
      border: 2px solid var(--bg-primary);
    }

    .timeline__entry time {
      display: block;
      margin-bottom: var(--space-1);
    }

    .timeline__role {
      font-size: var(--size-lg);
      margin: var(--space-1) 0;
    }

    .timeline__company {
      font-size: var(--size-sm);
      color: var(--text-secondary);
      margin: 0 0 var(--space-2) 0;
    }

    .timeline__desc {
      font-size: var(--size-base);
      color: var(--text-secondary);
      line-height: var(--leading-relaxed);
      margin: 0;
    }

    /* Tools: grouped by category */
    .tools-group {
      margin-bottom: var(--space-5);
    }

    .tools-group:last-child {
      margin-bottom: 0;
    }

    .tools-group__label {
      display: block;
      margin-bottom: var(--space-3);
      color: var(--accent-text);
    }

    .tools-grid {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
      gap: var(--space-4);
    }

    .tools-grid__item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-3);
      border-radius: var(--space-2);
      background: var(--bg-card);
      border: 1px solid var(--border-subtle);
    }

    .tools-grid__icon {
      width: 32px;
      height: 32px;
    }

    [data-theme="dark"] .tools-grid__icon {
      filter: none;
    }

    .tools-grid__name {
      font-size: var(--size-xs);
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--text-secondary);
      text-align: center;
    }

    /* Contact */
    .about-contact {
      padding: var(--space-7) 96px var(--space-8);
    }

    .about-contact .section-marker {
      margin-bottom: var(--space-5);
    }

    .about-contact__email {
      font-size: var(--size-xl);
      margin-bottom: var(--space-2);
    }

    .about-contact__email a {
      color: var(--text-primary);
      text-decoration: none;
    }

    .about-contact__email a:hover {
      color: var(--accent);
    }

    .about-contact__location {
      margin-bottom: var(--space-4);
    }

    .about-contact__links {
      display: flex;
      gap: var(--space-3);
    }

    .about-contact__link {
      font-family: var(--font-mono);
      font-size: var(--size-sm);
      text-transform: uppercase;
      letter-spacing: var(--tracking-wide);
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid var(--accent);
      padding-bottom: 1px;
    }

    .about-contact__link:hover {
      color: var(--accent-hover);
      border-color: var(--accent-hover);
    }

  }
</style>
