---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import '../styles/case-study.css';

interface Props {
  entry: CollectionEntry<'case-studies'>;
  prev: CollectionEntry<'case-studies'> | null;
  next: CollectionEntry<'case-studies'> | null;
}

const { entry, prev, next } = Astro.props;
const { title, role, timeline, tools, thumbnail, oneliner } = entry.data;
---
<BaseLayout title={`${title} - Adam Palencar`} description={oneliner}>
  <div class="case-study__progress" aria-hidden="true"></div>
  <article class="case-study">
    <header class="case-study__hero">
      <Image
        src={thumbnail}
        alt={`${title} hero image`}
        class="case-study__hero-image"
        widths={[600, 900, 1200]}
        sizes="(max-width: 768px) 100vw, (max-width: 1199px) 100vw, 1200px"
        loading="eager"
      />
      <h1 class="case-study__title">{title}</h1>
      <p class="case-study__oneliner">{oneliner}</p>
      <dl class="case-study__meta">
        <div class="case-study__meta-item">
          <dt>Role</dt>
          {role.split(', ').map(r => <dd>{r}</dd>)}
        </div>
        <div class="case-study__meta-item">
          <dt>Timeline</dt>
          <dd>{timeline}</dd>
        </div>
        <div class="case-study__meta-item">
          <dt>Tools</dt>
          {tools.map(t => <dd>{t}</dd>)}
        </div>
      </dl>
    </header>
    <div class="case-study__body">
      <slot />
    </div>
    <section class="case-study__cta">
      <h2 class="case-study__cta-heading">Want to work together?</h2>
      <p class="case-study__cta-text">I design interfaces that communicate. Let's talk.</p>
      <a href="/#contact" class="case-study__cta-link">Get in touch</a>
    </section>
    {(prev || next) && (
      <nav class="case-study__nav" aria-label="Case study navigation">
        {prev && <a href={`/work/${prev.id}`} class="case-study__nav-prev">{prev.data.title}</a>}
        {next && <a href={`/work/${next.id}`} class="case-study__nav-next">{next.data.title}</a>}
      </nav>
    )}
  </article>

  <script>
    let progressHandler: (() => void) | null = null;
    let carouselTimer: ReturnType<typeof setInterval> | null = null;
    let carouselTimers: ReturnType<typeof setInterval>[] = [];
    let resizeHandlers: (() => void)[] = [];
    let videoObserver: IntersectionObserver | null = null;

    document.addEventListener('astro:page-load', () => {
      const bar = document.querySelector('.case-study__progress') as HTMLElement;
      if (bar) {
        function updateProgress() {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          if (docHeight <= 0) return;
          bar.style.transform = `scaleX(${scrollTop / docHeight})`;
        }
        progressHandler = updateProgress;
        window.addEventListener('scroll', updateProgress, { passive: true });
        updateProgress();
      }

      const carousels = document.querySelectorAll('.cs-carousel');
      carouselTimers = [];
      carousels.forEach((carousel) => {
        const track = carousel.querySelector('.cs-carousel__track') as HTMLElement;
        const slides = track.querySelectorAll('.cs-carousel__slide');
        const count = slides.length;
        let current = 0;

        const dotsContainer = carousel.querySelector('.cs-carousel__dots') as HTMLElement;
        dotsContainer.innerHTML = '';
        for (let i = 0; i < count; i++) {
          const dot = document.createElement('button');
          dot.className = 'cs-carousel__dot' + (i === 0 ? ' cs-carousel__dot--active' : '');
          dot.setAttribute('aria-label', `Slide ${i + 1}`);
          dot.addEventListener('click', () => { goTo(i); resetTimer(); });
          dotsContainer.appendChild(dot);
        }

        const dots = dotsContainer.querySelectorAll('.cs-carousel__dot');
        const prevBtn = carousel.querySelector('.cs-carousel__prev') as HTMLElement;
        const nextBtn = carousel.querySelector('.cs-carousel__next') as HTMLElement;
        const captionEl = carousel.querySelector('.cs-carousel__caption') as HTMLElement | null;
        const viewport = carousel.querySelector('.cs-carousel__viewport') as HTMLElement;
        const captions = Array.from(slides).map(s => (s as HTMLElement).dataset.caption || '');
        if (captionEl && captions[0]) captionEl.textContent = captions[0];

        function sizeSlides() {
          const w = viewport.offsetWidth;
          slides.forEach(s => (s as HTMLElement).style.width = `${w}px`);
          track.style.transform = `translateX(-${current * w}px)`;
        }
        sizeSlides();
        window.addEventListener('resize', sizeSlides);
        resizeHandlers.push(sizeSlides);

        function goTo(index: number) {
          current = ((index % count) + count) % count;
          const w = viewport.offsetWidth;
          track.style.transform = `translateX(-${current * w}px)`;
          dots.forEach((d, i) => d.classList.toggle('cs-carousel__dot--active', i === current));
          if (captionEl && captions[current]) captionEl.textContent = captions[current];
        }

        prevBtn.addEventListener('click', () => { goTo(current - 1); resetTimer(); });
        nextBtn.addEventListener('click', () => { goTo(current + 1); resetTimer(); });

        function resetTimer() {
          if (carouselTimer) clearInterval(carouselTimer);
          carouselTimer = setInterval(() => goTo(current + 1), 5000);
          carouselTimers.push(carouselTimer);
        }

        carousel.addEventListener('mouseenter', () => { if (carouselTimer) clearInterval(carouselTimer); });
        carousel.addEventListener('mouseleave', () => resetTimer());

        resetTimer();
      });

      const autoplayVideos = document.querySelectorAll('video[data-autoplay-scroll]');
      if (autoplayVideos.length) {
        videoObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              video.play();
            } else {
              video.pause();
            }
          });
        }, { threshold: 0.4 });
        autoplayVideos.forEach((v) => videoObserver!.observe(v));
      }
    });

    document.addEventListener('astro:before-swap', () => {
      if (progressHandler) {
        window.removeEventListener('scroll', progressHandler);
        progressHandler = null;
      }
      if (carouselTimer) {
        clearInterval(carouselTimer);
        carouselTimer = null;
      }
      carouselTimers?.forEach(t => clearInterval(t));
      resizeHandlers.forEach(h => window.removeEventListener('resize', h));
      resizeHandlers = [];
      if (videoObserver) {
        videoObserver.disconnect();
        videoObserver = null;
      }
    });
  </script>
</BaseLayout>
